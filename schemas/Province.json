{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "properties": {
    "Province": {
      "$ref": "#/definitions/Province"
    }
  },
  "required": [
    "Province"
  ],
  "title": "Province",
  "definitions": {
    "Province": {
      "$id": "#/properties/Province",
      "type": "object",
      "title": "The Province Schema",
      "required": [
        "code",
        "name_en",
        "name_kh"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[0-9]{1,2}$",
          "description": "Unique 2-digit province code"
        },
        "name_en": {
          "type": "string",
          "description": "Name of the province in English"
        },
        "name_kh": {
          "type": "string",
          "description": "Name of the province in Khmer"
        }
      }
    }
  },
  "_osConfig": {
    "systemFields": [
      "osCreatedAt",
      "osUpdatedAt",
      "osCreatedBy",
      "osUpdatedBy"
    ],
    "uniqueIndexFields": [
      "code"
    ],
    "privateFields": [],
    "roles": [
      "admin"
    ],
    "inviteRoles": [
      "admin"
    ],
    "ownershipAttributes": [
    ]
  }
}
